# ── Clerk ──────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/2026/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/2026/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/2026/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/2026/onboarding

# ── Supabase ───────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ── Admin ──────────────────────────────────────────────────────────
ADMIN_PASSWORD=

# ── Square Payments ────────────────────────────────────────────────
# 1. Create an app at https://developer.squareup.com/apps
# 2. Copy credentials from the app dashboard:
#    - Access Token  → Credentials → Access token
#    - Application ID → Credentials → Application ID (starts with "sandbox-sq0idb-" or "sq0idp-")
#    - Location ID   → Locations → pick a location ID
# 3. Set NEXT_PUBLIC_SQUARE_ENVIRONMENT to "sandbox" for testing or "production" for live payments
# 4. Test with sandbox card: 4111 1111 1111 1111, any future expiry, any CVV, any ZIP
SQUARE_ACCESS_TOKEN=
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# ── Square Webhook ─────────────────────────────────────────────────
# 1. In your Square app dashboard → Webhooks → Add subscription
# 2. Set the URL to: https://your-domain.com/api/square-webhook
# 3. Subscribe to: payment.completed
# 4. Copy the Signature Key below
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_URL=

# ── Entry Fee (in cents) ──────────────────────────────────────────
# e.g. 6000 = $60.00, 10000 = $100.00
NEXT_PUBLIC_STANDARD_TEAM_PRICE=10000
NEXT_PUBLIC_OPEN_TEAM_PRICE=6000

# ── Resend (confirmation emails) ────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_ADDRESS=Sumobots <noreply@sumobots.ramsocunsw.org>
